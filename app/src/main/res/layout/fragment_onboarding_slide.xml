<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingStart="36dp"
    android:paddingEnd="36dp"
    android:paddingBottom="24dp"
    android:background="@android:color/transparent">

    <!-- Spacer atas -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Lingkaran Ilustrasi -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="center_horizontal"
        app:cardCornerRadius="90dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/ivSlideIcon"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:contentDescription="Onboarding Illustration" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Spacer tengah -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Judul -->
    <TextView
        android:id="@+id/tvSlideTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Judul Slide"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:lineSpacingMultiplier="1.2"
        android:layout_marginBottom="14dp"
        android:fontFamily="sans-serif-medium" />

    <!-- Deskripsi -->
    <TextView
        android:id="@+id/tvSlideDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Deskripsi slide ini."
        android:textColor="#CCE0F0FF"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.6"
        android:fontFamily="sans-serif" />

    <!-- Spacer bawah -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
